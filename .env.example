# LLM Provider (google / openai / deepseek)
LLM_PROVIDER=google
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=your-gemini-api-key

# TTS (edge-tts is free, no key needed)
TTS_PROVIDER=edge

