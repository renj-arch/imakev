# =============================================================================
# imakev — AI Video Generator
# ALL keys are OPTIONAL. The system works fully with procedural/stock content
# and pre-seeded content banks (500+ entries each, no APIs needed).
# =============================================================================

# ── LLM (for script generation) ──────────────────────────────────────────
# Optional. Without it, uses pre-seeded content banks (500 entries each).
# Free options: OpenRouter (moonshotai/kimi-k2.6:free), Google Gemini free tier
LLM_PROVIDER=openrouter
LLM_MODEL=moonshotai/kimi-k2.6:free
LLM_API_KEY=

# ── Text-to-Speech ───────────────────────────────────────────────────────
# edge = free, local, no API key needed (default)
# elevenlabs = requires API key
TTS_PROVIDER=edge

# ── Video Settings ───────────────────────────────────────────────────────
VIDEO_WIDTH=720
VIDEO_HEIGHT=1280
VIDEO_FPS=24

# ── YOUR BRAND ──────────────────────────────────────────────────────────
# Set this to your YouTube channel name — appears as a watermark on videos
BRAND_NAME=YourChannelName

# ── AI Video Generation (all optional) ───────────────────────────────────
# Free.ai — Wan 2.2 / CogVideoX (free tier, 30K tokens/day = ~6 videos)
# Sign up at https://free.ai (no credit card needed)
FREEAI_API_KEY=
FREEAI_VIDEO_MODEL=wan22-ti2v-5b

# Pollinations.ai — free video API (https://enter.pollinations.ai)
POLLINATIONS_KEY=

# OpenRouter video — uses your existing LLM_API_KEY for video generation
# Best free-tier: kwaivgi/kling-v3.0-std ($0.084/s, 1080p, 15s, native audio)
# Premium:       kwaivgi/kling-v3.0-pro ($0.16/s, 4K, 15s, native audio)
# Others:        google/veo-3.1-lite, bytedance/seedance-2.0, alibaba/wan-2.7
OPENROUTER_VIDEO_MODEL=kwaivgi/kling-v3.0-std

# HuggingFace token — for HF Spaces/Inference (free tier available)
HF_TOKEN=

# Seedance API — free daily credits
SEEDANCE_API_KEY=
