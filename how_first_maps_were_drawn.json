          {"type": "text", "x": 0.5, "y": 0.85, "text": "Faith, not geography, guided the pen", "font_size": 18, "fill": [120, 110, 100]}
        ],
        "atmosphere": {"particles": "none", "fog": false}
      }
    },
    {
