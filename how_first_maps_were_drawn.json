          {"type": "line", "x": 0.75, "y": 0.28, "x2": 0.82, "y2": 0.2, "stroke": [120, 100, 80], "stroke_width": 1},
          {"type": "label", "x": 0.5, "y": 0.55, "text": "Compass rose guided navigation", "font_size": 16, "fill": [80, 70, 55], "bg_color": [255, 250, 235]},
