    {
      "scene_num": 7,
      "title": "Measuring the World",
      "narration": "Explorers returned with new coastlines, and mapmakers faced a huge problem: how to draw a round world on flat paper.",
      "mood": "dramatic",
      "camera": null,
      "visual": {
        "bg": {"type": "gradient", "colors": [[180, 200, 225], [140, 170, 210]], "horizon": 0.5, "ground_color": [60, 80, 60]},
        "elements": [
          {"type": "text", "x": 0.5, "y": 0.05, "text": "MEASURING THE WORLD", "font_size": 28, "fill": [40, 35, 30]},
          {"type": "circle", "x": 0.35, "y": 0.4, "radius": 0.1, "fill": [100, 150, 200, 100], "stroke": [60, 100, 160], "stroke_width": 2},
          {"type": "rect", "x": 0.52, "y": 0.32, "width": 0.16, "height": 0.16, "fill": [200, 200, 180], "stroke": [120, 100, 80], "stroke_width": 2, "rx": 2},
          {"type": "arrow", "x": 0.48, "y": 0.35, "x2": 0.52, "y2": 0.35, "stroke": [180, 60, 60], "stroke_width": 2},
          {"type": "arrow", "x": 0.48, "y": 0.45, "x2": 0.52, "y2": 0.45, "stroke": [180, 60, 60], "stroke_width": 2},
          {"type": "label", "x": 0.5, "y": 0.55, "text": "Sphere on flat paper = distortion", "font_size": 16, "fill": [40, 35, 30], "bg_color": [255, 250, 240]},
          {"type": "ship", "x": 0.15, "y": 0.75, "scale": 0.4, "fill": [60, 50, 40], "sail_color": [200, 190, 180]},
          {"type": "text", "x": 0.5, "y": 0.85, "text": "The problem of projection was born", "font_size": 18, "fill": [100, 90, 80]}
        ],
        "atmosphere": {"particles": "none", "fog": false}
      }
    },
