        "elements": [
          {"type": "text", "x": 0.5, "y": 0.05, "text": "MEDIEVAL MAPS", "font_size": 30, "fill": [40, 35, 30]},
          {"type": "circle", "x": 0.5, "y": 0.4, "radius": 0.15, "fill": [230, 215, 190], "stroke": [140, 120, 100], "stroke_width": 2},
          {"type": "text", "x": 0.5, "y": 0.28, "text": "East", "font_size": 14, "fill": [120, 100, 80]},
          {"type": "text", "x": 0.35, "y": 0.4, "text": "Asia", "font_size": 14, "fill": [160, 130, 80]},
