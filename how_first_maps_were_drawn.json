{
  "title": "How the First Maps Were Drawn",
  "scenes": [
    {
      "scene_num": 1,
      "title": "A World Without Maps",
      "narration": "Imagine a world with no maps. No GPS, no street signs, no way to know what lay beyond the next hill.",
      "mood": "mysterious",
      "camera": "ken_burns_in",
      "visual": {
        "bg": {"type": "gradient", "colors": [[200, 190, 180], [160, 150, 140]], "horizon": 0.65, "ground_color": [80, 70, 55]},
        "elements": [
          {"type": "text", "x": 0.5, "y": 0.05, "text": "A WORLD WITHOUT MAPS", "font_size": 30, "fill": [40, 35, 30]},
          {"type": "human", "x": 0.3, "y": 0.58, "scale": 0.9, "fill": [100, 70, 50], "label": "ancient traveler"},
          {"type": "human", "x": 0.7, "y": 0.58, "scale": 0.9, "fill": [80, 90, 70], "label": "wanderer"},
          {"type": "text", "x": 0.5, "y": 0.82, "text": "Only word of mouth and memory", "font_size": 18, "fill": [100, 90, 80]}
        ],
        "atmosphere": {"particles": "none", "fog": false}
      }
    },
    {
      "scene_num": 2,
      "title": "Navigation by Nature",
      "narration": "The earliest travelers read the land itself: the stars, the sun, rivers, and mountain peaks.",
      "mood": "peaceful",
      "camera": "pan_right",
      "visual": {
        "bg": {"type": "night", "colors": [[10, 8, 30], [20, 15, 45]], "horizon": 0.6, "ground_color": [20, 18, 15]},
        "elements": [
          {"type": "text", "x": 0.5, "y": 0.05, "text": "NAVIGATION BY NATURE", "font_size": 28, "fill": [220, 210, 200]},
          {"type": "star", "x": 0.5, "y": 0.12, "count": 30, "brightness": 200},
          {"type": "mountain", "x": 0.25, "y": 0.5, "scale": 0.7, "fill": [40, 35, 50]},
          {"type": "mountain", "x": 0.75, "y": 0.55, "scale": 0.5, "fill": [35, 30, 45]},
          {"type": "human", "x": 0.5, "y": 0.65, "scale": 0.7, "fill": [60, 50, 70], "label": "navigator"},
          {"type": "text", "x": 0.5, "y": 0.85, "text": "The sky was the first map", "font_size": 18, "fill": [180, 170, 160]}
        ],
        "atmosphere": {"particles": "none", "fog": false}
      }
    },
    {
      "scene_num": 3,
      "title": "The First Map",
      "narration": "Around 600 BC, the Babylonians scratched the oldest known map onto a clay tablet.",
      "mood": "mysterious",
      "camera": "dolly_in",
      "visual": {
        "bg": {"type": "indoor", "wall_color": [200, 180, 160], "floor_color": [140, 120, 100]},
        "elements": [
          {"type": "text", "x": 0.5, "y": 0.05, "text": "THE FIRST MAP", "font_size": 30, "fill": [40, 35, 30]},
          {"type": "rect", "x": 0.4, "y": 0.3, "width": 0.25, "height": 0.3, "fill": [180, 160, 130], "stroke": [120, 100, 80], "stroke_width": 2},
          {"type": "circle", "x": 0.5, "y": 0.4, "radius": 0.08, "fill": [200, 185, 150], "stroke": [100, 85, 60], "stroke_width": 2},
          {"type": "text", "x": 0.5, "y": 0.42, "text": "Imago Mundi", "font_size": 14, "fill": [80, 70, 55]},
          {"type": "label", "x": 0.5, "y": 0.68, "text": "Babylon at the center of the world", "font_size": 16, "fill": [80, 70, 55], "bg_color": [255, 245, 230]},
          {"type": "text", "x": 0.5, "y": 0.88, "text": "Drawn on clay, baked in the sun", "font_size": 18, "fill": [120, 110, 100]}
        ],
        "atmosphere": {"particles": "none", "fog": false}
      }
    },
    {
      "scene_num": 4,
      "title": "The Greek Revolution",
      "narration": "The ancient Greeks realized the Earth was a sphere and began measuring it with geometry.",
      "mood": "hopeful",
      "camera": null,
      "visual": {
        "bg": {"type": "solid", "color": [250, 248, 240]},
        "elements": [
          {"type": "text", "x": 0.5, "y": 0.05, "text": "THE GREEK REVOLUTION", "font_size": 28, "fill": [40, 35, 30]},
          {"type": "circle", "x": 0.5, "y": 0.35, "radius": 0.1, "fill": [200, 220, 255], "stroke": [60, 100, 180], "stroke_width": 2},
          {"type": "text", "x": 0.5, "y": 0.33, "text": "Earth", "font_size": 14, "fill": [60, 100, 180]},
          {"type": "label", "x": 0.25, "y": 0.55, "text": "Anaximander", "font_size": 18, "fill": [40, 35, 30], "bg_color": [255, 255, 240]},
          {"type": "label", "x": 0.25, "y": 0.62, "text": "6th century BC", "font_size": 14, "fill": [120, 110, 100], "bg_color": [255, 255, 240]},
          {"type": "label", "x": 0.75, "y": 0.55, "text": "Ptolemy", "font_size": 18, "fill": [40, 35, 30], "bg_color": [255, 255, 240]},
          {"type": "label", "x": 0.75, "y": 0.62, "text": "Added latitude & longitude", "font_size": 14, "fill": [120, 110, 100], "bg_color": [255, 255, 240]},
          {"type": "line", "x": 0.3, "y": 0.38, "x2": 0.7, "y2": 0.38, "stroke": [180, 80, 60], "stroke_width": 2},
          {"type": "line", "x": 0.5, "y": 0.25, "x2": 0.5, "y2": 0.5, "stroke": [60, 100, 180], "stroke_width": 2},
          {"type": "text", "x": 0.5, "y": 0.82, "text": "Geometry made mapmaking a science", "font_size": 18, "fill": [120, 110, 100]}
        ],
        "atmosphere": {"particles": "none", "fog": false}
      }
    },
    {
